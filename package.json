{
  "name": "font-compare",
  "version": "1.3.2",
  "description": "An Electron app to compare system fonts side by side.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "font",
    "compare"
  ],
  "author": "fangsunjian",
  "license": "MIT",
  "build": {
    "appId": "com.fangsunjian.fontcompare",
    "productName": "Font Compare",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  }
}
